# Organization UUID — created by Recursiv MCP `provision_app` (or in the dashboard).
# All per-user API keys created at sign-up are scoped to this org.
RECURSIV_ORG_ID=

# Project UUID — owns your Postgres + storage buckets. Created with the org.
RECURSIV_PROJECT_ID=

# Optional: override the API base URL (default: https://recursiv.io/api/v1).
# Only set when running against staging or a self-hosted Recursiv.
# RECURSIV_API_BASE_URL=

# NOTE: There is intentionally no RECURSIV_API_KEY env var here.
# This template uses the per-user API key pattern: each user's key is created
# at sign-up via signUpAndCreateKey, stored in an HTTP-only cookie, and used
# for every subsequent SDK call. The deployed app holds no god platform key.
