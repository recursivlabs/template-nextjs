# Organization UUID — auto-injected by `provision_app` when Claude creates
# this project via the Recursiv MCP. All per-user API keys created at sign-up
# are scoped to this org. The org has `allow_public_signup=true` so new
# signups auto-join.
RECURSIV_ORG_ID=

# Project UUID — owns your Postgres + storage buckets. Auto-injected by
# `provision_app` together with RECURSIV_ORG_ID.
RECURSIV_PROJECT_ID=

# Optional: override the API base URL (default: https://api.recursiv.io/api/v1).
# Only set when running against staging or a self-hosted Recursiv.
# RECURSIV_API_BASE_URL=

# NOTE: There is intentionally no RECURSIV_API_KEY here. Each user's
# per-user key is created at sign-up via the per-user API key pattern,
# stored in an HTTP-only cookie, and used for every subsequent SDK call.
# The deployed app holds no platform key.
