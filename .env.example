# Recursiv API key — get one at https://recursiv.io → Org Settings → API Keys
RECURSIV_API_KEY=

# Project UUID — created via Recursiv MCP (`create_project` or `provision_app`)
# or in the dashboard. Required for r.databases / r.storage.
RECURSIV_PROJECT_ID=

# Organization UUID — created when you sign up; used by multi-tenant flows.
RECURSIV_ORG_ID=

# Optional: override API base URL (default: https://recursiv.io/api/v1)
# Only set this when running against staging or a self-hosted Recursiv.
# RECURSIV_API_BASE_URL=
